FROM alpine:3.22

RUN apk add --no-cache ca-certificates

WORKDIR /app

# In GoReleaser v2, the binary for the target platform is provided in the context.
# We can use ARG TARGETPLATFORM to match the architecture.
ARG TARGETPLATFORM
COPY ${TARGETPLATFORM}/firstclick /app/firstclick

# Include the static directory which GoReleaser provides in the root of the context
COPY static /app/static

EXPOSE 8080

ENTRYPOINT ["/app/firstclick"]
